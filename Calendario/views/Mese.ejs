<!DOCTYPE html>
<html lang="it">
  <head>
    <title>UniBo Smile-Calendario</title>
    <link rel="stylesheet" href="./Calendario.css" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script type="importmap">
      {
        "imports": {
          "vue": "https://unpkg.com/vue@3/dist/vue.esm-browser.js"
        }
      }
    </script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>

    <script type="module">
      let user = "Lollo";
      const { createApp, ref } = Vue;
      import {
        Day,
        Week,
        Month,
        Year,
        Decade,
        ActualWeek,
        ActualMonth,
        ActualYear,
        Today,
      } from "./Calendario.js";

      const this_month = Vue.createApp({
        data() {
          let m = ActualMonth();
          let y = ActualYear();
          const month = new Month(m, y);
          month.Print();
          return {
            month: month,
            today: Today(),
            monthNames: [
              "Gennaio",
              "Febbraio",
              "Marzo",
              "Aprile",
              "Maggio",
              "Giugno",
              "Luglio",
              "Agosto",
              "Settembre",
              "Ottobre",
              "Novembre",
              "Dicembre",
            ],
          };
        },
      });
      this_month.mount("#this_month");

      const general_month = Vue.createApp({
        data() {
          let m = ActualMonth();
          let y = ActualYear();
          const month = new Month(m, y);
          const day = new Day(1, 1, 1); //inizializzazione casuale, tanto dopo viene modficato
          month.Print(); //inizializzazione del mese nel format giusto, vedi Calendario.js
          return {
            month: month,
            today: Today(),
            monthNames: [
              "Gennaio",
              "Febbraio",
              "Marzo",
              "Aprile",
              "Maggio",
              "Giugno",
              "Luglio",
              "Agosto",
              "Settembre",
              "Ottobre",
              "Novembre",
              "Dicembre",
            ],
            show: false,
            showEvents: true,
            showNotes: false,
            day: day,
            decade: new Decade(2024),
            note: "",
            changeNotes: false,
            eventi: this.loadEventi(1, 1, 2024), //a caso, deve essere oridnato
            changeEventi: false,
          };
        },
        methods: {
          Prec() {
            //ritorna mese precedente
            if (this.month.m > 1) {
              this.month = new Month(this.month.m - 1, this.month.y);
            } else this.month = new Month(12, this.month.y - 1);
            this.month.Print();
          },
          Next() {
            //successivo
            if (this.month.m < 12) {
              this.month = new Month(this.month.m + 1, this.month.y);
            } else this.month = new Month(1, this.month.y + 1);
            this.month.Print();
          },
          async loadEventi(d, m, y) {
            if (!this.changeEventi) {
              try {
                const response = await fetch("http://127.0.0.1:3000/data");
                const data = await response.json();
                this.eventi =
                  data.user.User.grid.decade[y - 2024].year[m - 1].month[
                    d - 1
                  ].eventi;
              } catch (error) {
                console.log("Errore: " + error);
              }
            }
          },
          loaded() {
            this.changeEventi = true;
          },
          async loadNote(d, m, y) {
            try {
              const response = await fetch("http://127.0.0.1:3000/data");
              const data = await response.json();
              this.note =
                data.user.User.grid.decade[y - 2024].year[m - 1].month[
                  d - 1
                ].note;
            } catch (error) {
              console.log("Errore: " + error);
            }
          },
        },
      });
      general_month.mount("#general_month");
    </script>
  </head>
  <body>
    <nav class="navbar col mx-auto" id="Header">
      <ul class="navbar-nav col mx-auto">
        <div class="row mx-auto">
          <li class="nav-item col">
            <a href="" class="nav-link">Appunti</a>
          </li>
          <li class="nav-item col d-none d-sm-block">
            <a href="" class="nav-link">Timer</a>
          </li>
          <li class="nav-item col">
            <a
              href="../../Introduzione/Index.html"
              class="nav-link d-none d-sm-block"
              target="_blank"
              >Help</a
            >
          </li>
          <li class="nav-item col">
            <div class="col">
              <button class="btn col mx-auto" id="button-event">
                Aggiungi evento <img src="./Assets/journal-plus.svg" alt="+" />
              </button>
            </div>
          </li>
        </div>
      </ul>
      <ul class="navbar-nav">
        <div class="row">
          <li class="col d-flex justify-content-end">
            <button type="button" class="btn" id="button-header" onclick="">
              Logout
            </button>
          </li>
          <li
            class="col d-flex justify-content-end d-none d-md-blocl d-xl-block"
          >
            <button
              type="button"
              class="btn"
              id="button-header"
              onclick="location.href='../../Singup/Index.html'"
            >
              Altri account
            </button>
          </li>
          <div class="col-1"></div>
        </div>
      </ul>
    </nav>

    <div class="row">
      <div class="col-3 d-none d-xl-block" id="tenda">
        <div class="col" id="this_month">
          <div class="row" id="period">
            <h4 class="col d-flex justify-content-center">
              {{ monthNames[month.m - 1] }} {{ month.y }}
            </h4>
          </div>
          <div class="row">
            <div class="col-11 mx-auto" id="cal-mini">
              <div class="row">
                <div
                  class="col d-flex align-contents-center justify-content-center"
                  id="weekdays"
                >
                  <div class="col">LUN</div>
                  <div class="col">MAR</div>
                  <div class="col">MER</div>
                  <div class="col">GIO</div>
                  <div class="col">VEN</div>
                  <div class="col">SAB</div>
                  <div class="col">DOM</div>
                </div>
              </div>
              <div v-for="i in 6" :key="i" class="row" id="days">
                <div v-for="j in 7" :key="j" class="col">
                  <!--Iniziano una serie di if per capire quali, come e quanti giorni mostrare nella tabella-->
                  <div v-if="month.print[(i - 1) * 7 + (j - 1)].bold">
                    <!--Se fanno perte del mese "vero" (vedi Calendario.js) vanno in grassetto"-->
                    <div
                      v-if="today.d==month.print[(i - 1) * 7 + (j - 1)].d &&
                      today.m==month.print[(i - 1) * 7 + (j - 1)].m &&
                      today.y==month.print[(i - 1) * 7 + (j - 1)].y"
                    >
                      <!--Se e' oggi grassetto, background nero e colore bianco-->
                      <button class="text-white bg-dark" id="button-cal">
                        <b>{{ month.print[(i - 1) * 7 + (j - 1)].d }}</b>
                      </button>
                    </div>
                    <div v-else>
                      <!--Altrimenti solo grassetto-->
                      <button id="button-cal">
                        <b>{{ month.print[(i - 1) * 7 + (j - 1)].d }}</b>
                      </button>
                    </div>
                  </div>
                  <div v-else>
                    <!--Se non fanno parte del mese in grigio-->
                    <button class="text-secondary" id="button-cal">
                      {{ month.print[(i - 1) * 7 + (j - 1)].d }}
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="row"><hr class="hr-blurry" id="blurry" /></div>
          <div class="col">
            <div class="row"><h4>Eventi di oggi</h4></div>
            <div class="row">
              <button class="btn col-8 mx-auto" id="button-event">
                Aggiungi evento <img src="./Assets/journal-plus.svg" alt="+" />
              </button>
            </div>
          </div>
          <div class="row"><hr class="hr-blurry" id="blurry" /></div>
          <div class="col">
            <div class="row"><h4>I miei calendari</h4></div>
            <div class="row">
              <button class="btn col-8 mx-auto" id="button-event">
                Aggiungi calendario
                <img src="./Assets/journal-plus.svg" alt="+" />
              </button>
            </div>
          </div>
        </div>
      </div>

      <div class="col-11 col-md-8 mx-auto">
        <div class="row">
          <div class="col">
            <div class="dropdown">
              <button
                type="button"
                class="btn dropdown-toggle"
                data-bs-toggle="dropdown"
                id="drop"
              >
                <b>View</b>
              </button>
              <ul class="dropdown-menu">
                <li>
                  <button class="btn" @click="showMonth=false; showWeek=true">
                    Settimana
                  </button>
                </li>
                <li>
                  <button class="btn" @click="showMonth=true; showWeek=false">
                    Mese
                  </button>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <div class="col" id="general_month" v-if="showMonth">
          <div class="row">
            <h1 class="col d-flex justify-content-center">
              <button class="col" id="arrow" @click="Prec">
                <img src="./Assets/arrow-left-circle.svg" alt="Prec" />
              </button>
              {{ monthNames[month.m - 1] }} {{ month.y }}
              <button class="col" id="arrow" @click="Next">
                <img src="./Assets/arrow-right-circle.svg" alt="Next" />
              </button>
            </h1>
          </div>
          <div class="row" id="cal">
            <div class="col d-flex align-contents-center" id="weekdays">
              <div class="col">LUN</div>
              <div class="col">MAR</div>
              <div class="col">MER</div>
              <div class="col">GIO</div>
              <div class="col">VEN</div>
              <div class="col">SAB</div>
              <div class="col">DOM</div>
            </div>
            <div v-for="i in 6" :key="i" class="row" id="days">
              <div v-for="j in 7" :key="j" class="col">
                <div v-if="month.print[(i - 1) * 7 + (j - 1)].bold">
                  <div
                    v-if="today.d==month.print[(i - 1) * 7 + (j - 1)].d &&
                  today.m==month.print[(i - 1) * 7 + (j - 1)].m &&
                  today.y==month.print[(i - 1) * 7 + (j - 1)].y"
                  >
                    <button
                      class="btn text-white bg-dark"
                      id="button-cal"
                      @click="show=!show; 
                      day.d=month.print[(i - 1) * 7 + (j - 1)].d; 
                      day.m=month.print[(i - 1) * 7 + (j - 1)].m; 
                      day.y=month.print[(i - 1) * 7 + (j - 1)].y"
                    >
                      <!--Assegno valori a day per fare la transizione coi valori dell'elemento selezionato-->
                      <b>{{ month.print[(i - 1) * 7 + (j - 1)].d }}</b>
                    </button>
                  </div>
                  <div v-else>
                    <button
                      class="btn"
                      id="button-cal"
                      @click="show=!show; 
                      day.d=month.print[(i - 1) * 7 + (j - 1)].d; 
                      day.m=month.print[(i - 1) * 7 + (j - 1)].m; 
                      day.y=month.print[(i - 1) * 7 + (j - 1)].y"
                    >
                      <b>{{ month.print[(i - 1) * 7 + (j - 1)].d }}</b>
                    </button>
                  </div>
                </div>
                <div v-else>
                  <button
                    class="btn text-secondary"
                    id="button-cal"
                    @click="show=!show;
                    day.d=month.print[(i - 1) * 7 + (j - 1)].d;
                    day.m=month.print[(i - 1) * 7 + (j - 1)].m; 
                    day.y=month.print[(i - 1) * 7 + (j - 1)].y"
                  >
                    {{ month.print[(i - 1) * 7 + (j - 1)].d }}
                  </button>
                </div>
              </div>
            </div>
          </div>
          <Transition>
            <div
              v-if="show"
              class="modal-mask col d-flex justify-content-center align-items-center"
            >
              <div class="modal-container">
                <div class="row">
                  <div class="col d-flex justify-content-end">
                    <button
                      @click="show=false; changeEventi=false; changeNotes=false;
                      showEvent=true; showNotes=false"
                      id="button-close"
                      class="btn"
                    >
                      <a
                        href=""
                        class="link-offset-2 link-underline link-underline-opacity-0"
                        >Chiudi <img src="./Assets/x-circle.svg" alt="X"
                      /></a>
                    </button>
                  </div>
                </div>
                <div class="col d-flex justify-content-center">
                  <h2>
                    <!--Sfrutto quei valori per mostrare la data selezionata-->
                    <b>{{ day.d }} {{ monthNames[day.m - 1] }} {{ day.y }}</b>
                  </h2>
                </div>
                <nav class="navbar navbar-light bg-light" id="transition">
                  <a class="navbar-brand">Visualizza</a>
                  <ul class="nav nav-pills">
                    <li class="nav-item">
                      <a
                        class="nav-link"
                        href="#eventi"
                        id="a-tran"
                        @click="showEvents=true; showNotes=false"
                        >Eventi</a
                      >
                    </li>
                    <li class="nav-item">
                      <a
                        class="nav-link"
                        href="#note"
                        id="a-tran"
                        @click="showEvents=false; showNotes=true"
                        >Note</a
                      >
                    </li>
                    <li class="nav-item">
                      <a
                        class="nav-link"
                        href="#appunti"
                        id="a-tran"
                        @click="showEvents=false; showNotes=true"
                        >Appunti(da fare)</a
                      >
                    </li>
                  </ul>
                </nav>
                <div data-spy="scroll" data-offset="0">
                  <div class="col" id="events" v-if="showEvents">
                    <div class="row"><h4>Eventi</h4></div>
                    <div class="row" v-on="loadEventi(day.d, day.m, day.y)">
                      {{ loaded() }}
                      <div class="row" v-for="i in 3">
                        <div class="col" v-for="j in 3" id="events-cont">
                          <b>Ora:</b> {{ eventi[(i - 1) * 3 + j - 1].i }} -
                          {{ eventi[(i - 1) * 3 + j - 1].f }}
                          <br />
                          {{ eventi[(i - 1) * 3 + j - 1].event }}<br />
                        </div>
                      </div>
                    </div>
                    <div class="row">
                      <button class="btn col-8 mx-auto" id="button-event-int">
                        Aggiungi evento
                        <img src="./Assets/journal-plus.svg" alt="+" />
                      </button>
                      <button class="btn col-8 mx-auto" id="button-event-int">
                        Modifica evento
                        <img src="./Assets/journal-plus.svg" alt="+" />
                      </button>
                    </div>
                  </div>
                  <div class="col" id="notes" v-if="showNotes">
                    <div class="row">
                      <h4>Note</h4>
                    </div>
                    <div class="row" v-if="!changeNotes">
                      <p id="cont-note" v-on="loadNote(day.d, day.m, day.y)">
                        <!--Qui le note della data. Devo cambiarle e mostrarle nuove-->
                        {{ note }}
                      </p>
                    </div>
                    <form action="/data" method="post">
                      <div class="row mx-auto" v-if="changeNotes">
                        <div class="col mx-auto">
                          <input
                            type="text"
                            class="form-control"
                            id="insert-note"
                            v-model="note"
                            name="note"
                          />
                        </div>
                      </div>
                      <div
                        class="row d-flex justify-content-end"
                        v-if="changeNotes"
                      >
                        <div class="col-4 col-sm-3 col-xl-2">
                          <button
                            class="btn"
                            id="button-close-note"
                            @click="changeNotes=false"
                          >
                            Cancel
                          </button>
                        </div>
                        <div class="col-5">
                          <button
                            class="btn"
                            id="button-note"
                            type="submit"
                          >
                            Modifica <img src="./Assets/pencil.svg" alt="+" />
                          </button>
                        </div>
                      </div>
                    </form>
                    <div class="row">
                      <button
                        class="btn col-8 mx-auto"
                        id="button-note"
                        @click="changeNotes=true"
                        v-if="!changeNotes"
                      >
                        Modifica note <img src="./Assets/pencil.svg" alt="+" />
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </Transition>
        </div>
      </div>
    </div>
  </body>
</html>
